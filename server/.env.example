NODE_ENV=development
PORT=3000

# SQLite local (dev). Para Postgres: postgresql://user:pass@host:5432/db?schema=public
DATABASE_URL="file:./dev.db"

# CORS — origem do client em dev
CLIENT_ORIGIN=http://localhost:5173

# JWT — mínimo 32 caracteres. Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio_de_pelo_menos_32_chars
JWT_EXPIRES_IN=7d

# Anthropic — obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar OAuth — crie em https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/secretaria/agenda/callback

# Asaas (cobranças e Pix) — https://www.asaas.com/
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# DataJud CNJ — chave pública gratuita (https://datajud-wiki.cnj.jus.br)
DATAJUD_API_KEY=cDZwSXNkN3dLdzkwUGJsOA==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
# Provedor de dados de tribunais: datajud | judit
TRIBUNAL_API_PROVIDER=datajud
# JUDIT (pago, https://judit.io) — preencher quando contratar
JUDIT_API_KEY=
