// Prisma schema — Parceriza
// Plataforma jurídica com IA integrada.
//
// NOTA: SQLite no Prisma 5.x não suporta enums. Os campos abaixo usam String
// com defaults documentados. A validação de valores permitidos é feita no
// layer de aplicação (Zod). Constantes em src/lib/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE
// ============================================================

model Plano {
  id             String   @id @default(cuid())
  // codigo: STARTER | PRO | ESCRITORIO
  codigo         String   @unique
  nome           String
  preco          Decimal
  descricao      String?
  limiteServicos Int?
  limiteAnuncios Int?
  bonusTokens    Int      @default(0)
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  advogados Advogado[]

  @@map("planos")
}

model Advogado {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  nome        String
  oab         String
  oabUf       String
  telefone    String?
  bio         String?
  avatarUrl   String?
  saldoTokens Int      @default(0)
  ativo       Boolean  @default(true)

  planoId String?
  plano   Plano?  @relation(fields: [planoId], references: [id])

  agenteConfig     AgenteConfig?
  agenteWhatsapp   AgenteWhatsapp?
  agendaConfig     AgendaConfig?
  financeiroConfig FinanceiroConfig?

  tesesCriadas     Tese[]               @relation("TeseCriador")
  servicos         Servico[]
  parceriasOrigem  Parceria[]           @relation("ParceriaOrigem")
  parceriasDestino Parceria[]           @relation("ParceriaDestino")
  avaliacoesFeitas Avaliacao[]
  transacoes       Transacao[]
  anuncios         Anuncio[]
  documentos       Documento[]
  monitores        ProcessoMonitor[]
  agentesCriados   AgenteEspecialista[]
  avaliacoesAgente AvaliacaoAgente[]

  jobsSugeridos        JobCatalogo[]        @relation("JobSugerido")
  ofertas              JobOferta[]
  leadsCapturados      Lead[]               @relation("LeadCaptor")
  leadsMatch           Lead[]               @relation("LeadMatch")
  conversasAgente      ConversaAgente[]
  conversasSecretaria   SecretariaConversa[]
  tarefasCompletadas    AdvogadoTarefa[]
  indicacoesFeitas      IndicacaoToken[]        @relation("IndicacaoIndicador")
  indicacoesRecebidas   IndicacaoToken[]        @relation("IndicacaoIndicado")
  saques                SaqueToken[]
  historicoParceiros    HistoricoTokenParceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([oab, oabUf])
  @@index([oabUf])
  @@index([nome])
  @@map("advogados")
}

model Tese {
  id String @id @default(cuid())
  // area: TRABALHISTA | CIVIL | CONSUMIDOR | PREVIDENCIARIO | TRIBUTARIO |
  //       CRIMINAL | EMPRESARIAL | FAMILIA | IMOBILIARIO | ADMINISTRATIVO |
  //       CONSTITUCIONAL | AMBIENTAL | DIGITAL | OUTROS
  area      String
  titulo    String
  descricao String?

  criadorId String?
  criador   Advogado? @relation("TeseCriador", fields: [criadorId], references: [id])

  servicos Servico[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area])
  @@index([titulo])
  @@map("teses")
}

model Servico {
  id        String  @id @default(cuid())
  titulo    String
  descricao String
  valor     Decimal
  ativo     Boolean @default(true)

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  teseId String
  tese   Tese   @relation(fields: [teseId], references: [id])

  parcerias  Parceria[]
  avaliacoes Avaliacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, ativo])
  @@index([teseId, ativo])
  @@map("servicos")
}

model Parceria {
  id            String   @id @default(cuid())
  comissaoPct   Float
  valorAcordado Decimal?
  observacoes   String?
  // status: PENDENTE | ACEITA | RECUSADA | ATIVA | FINALIZADA | CANCELADA
  status        String   @default("PENDENTE")

  advogadoOrigemId String
  advogadoOrigem   Advogado @relation("ParceriaOrigem", fields: [advogadoOrigemId], references: [id])

  advogadoDestinoId String
  advogadoDestino   Advogado @relation("ParceriaDestino", fields: [advogadoDestinoId], references: [id])

  servicoId String?
  servico   Servico? @relation(fields: [servicoId], references: [id])

  aceitaEm     DateTime?
  finalizadaEm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoOrigemId, status])
  @@index([advogadoDestinoId, status])
  @@index([status])
  @@map("parcerias")
}

model Avaliacao {
  id         String  @id @default(cuid())
  nota       Int
  comentario String?

  servicoId String
  servico   Servico @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  autorId String
  autor   Advogado @relation(fields: [autorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([servicoId, autorId])
  @@index([servicoId])
  @@map("avaliacoes")
}

model Transacao {
  id String @id @default(cuid())
  // tipo: CREDITO | DEBITO
  tipo         String
  // origem: COMPRA | BONUS | PAGAMENTO_SERVICO | COMISSAO_PARCERIA |
  //         ANUNCIO | REEMBOLSO | AJUSTE
  origem       String
  quantidade   Int
  descricao    String?
  referenciaId String?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([advogadoId, createdAt])
  @@index([origem])
  @@map("transacoes")
}

model Anuncio {
  id        String  @id @default(cuid())
  titulo    String
  descricao String
  mediaUrl  String?
  // modelo: CPC | CPM
  modelo         String
  valorLance     Decimal
  orcamentoTotal Decimal
  gastoAcumulado Decimal   @default(0)
  impressoes     Int       @default(0)
  cliques        Int       @default(0)
  // status: RASCUNHO | ATIVO | PAUSADO | ENCERRADO
  status         String    @default("RASCUNHO")
  inicioEm       DateTime?
  fimEm          DateTime?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, status])
  @@index([status, modelo])
  @@map("anuncios")
}

// ============================================================
// IA & WHATSAPP
// ============================================================

model AgenteConfig {
  id            String  @id @default(cuid())
  nome          String  @default("Assistente")
  personalidade String?
  tomDeVoz      String?
  temperatura   Float   @default(0.7)
  promptSistema String?
  // modelo: CLAUDE_OPUS | CLAUDE_SONNET | CLAUDE_HAIKU | GPT_4 | GEMINI
  modelo        String  @default("CLAUDE_SONNET")

  advogadoId String   @unique
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agente_config")
}

model AgenteWhatsapp {
  id             String  @id @default(cuid())
  numeroTelefone String?
  // statusConexao: DESCONECTADO | AGUARDANDO_QR | CONECTADO | ERRO | EXPIRADO
  statusConexao   String    @default("DESCONECTADO")
  sessionData     String?
  ultimoQrEm      DateTime?
  ultimaConexaoEm DateTime?

  advogadoId String   @unique
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statusConexao])
  @@map("agente_whatsapp")
}

model AgendaConfig {
  id                  String    @id @default(cuid())
  googleAccessToken   String?
  googleRefreshToken  String?
  googleCalendarId    String?
  fusoHorario         String    @default("America/Sao_Paulo")
  // horariosDisponiveis: JSON string. Ex: {"seg":[{"ini":"09:00","fim":"12:00"}],...}
  horariosDisponiveis String?
  conectadoEm         DateTime?

  advogadoId String   @unique
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agenda_config")
}

model FinanceiroConfig {
  id       String  @id @default(cuid())
  pixChave String?
  // contaBancaria: JSON {banco, agencia, conta, tipo}
  contaBancaria String?
  // tabelaHonorarios: JSON [{descricao, valor}, ...]
  tabelaHonorarios String?
  regrasCobranca   String?

  advogadoId String   @unique
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("financeiro_config")
}

model Documento {
  id               String @id @default(cuid())
  nome             String
  mimetype         String
  tamanho          Int
  urlArmazenamento String
  // origem: WHATSAPP | UPLOAD | EMAIL | API
  origem    String
  // status: RECEBIDO | PROCESSANDO | PROCESSADO | ERRO
  status    String  @default("RECEBIDO")
  resumoIA  String?
  // metadados: JSON livre
  metadados String?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, status])
  @@index([origem])
  @@map("documentos")
}

// ============================================================
// RETAGUARDA JURÍDICA
// ============================================================

model ProcessoMonitor {
  id        String @id @default(cuid())
  documento String
  // tipoDocumento: CPF | CNPJ
  tipoDocumento       String
  nomeMonitorado      String?
  ativo               Boolean   @default(true)
  ultimaVerificacaoEm DateTime?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  processos Processo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([advogadoId, documento])
  @@index([advogadoId, ativo])
  @@index([documento])
  @@map("processo_monitores")
}

model Processo {
  id             String  @id @default(cuid())
  numeroProcesso String
  tribunal       String?
  vara           String?
  classe         String?
  assunto        String?
  // status: ATIVO | ARQUIVADO | SUSPENSO | TRANSITADO_JULGADO | DESCONHECIDO
  status              String    @default("DESCONHECIDO")
  // partes: JSON [{nome, tipo, papel}, ...]
  partes              String?
  // movimentacoes: JSON [{data, titulo, descricao}, ...]
  movimentacoes       String?
  resumoIA            String?
  ultimaAtualizacaoEm DateTime?

  monitorId String
  monitor   ProcessoMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([monitorId, numeroProcesso])
  @@index([numeroProcesso])
  @@index([status])
  @@map("processos")
}

model AgenteEspecialista {
  id            String @id @default(cuid())
  nome          String
  descricao     String
  // area: ver lista em Tese.area
  area          String
  promptSistema String
  // exemplos: JSON [{input, output}, ...]
  exemplos    String?
  precoTokens Int     @default(0)
  publico     Boolean @default(false)
  aprovado    Boolean @default(false)
  totalUsos   Int     @default(0)

  criadorId String
  criador   Advogado @relation(fields: [criadorId], references: [id], onDelete: Cascade)

  avaliacoes AvaliacaoAgente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area, publico, aprovado])
  @@index([criadorId])
  @@index([nome])
  @@map("agentes_especialistas")
}

model AvaliacaoAgente {
  id         String  @id @default(cuid())
  nota       Int
  comentario String?

  agenteId String
  agente   AgenteEspecialista @relation(fields: [agenteId], references: [id], onDelete: Cascade)

  autorId String
  autor   Advogado @relation(fields: [autorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([agenteId, autorId])
  @@index([agenteId])
  @@map("avaliacoes_agente")
}

model TarefaToken {
  id               String  @id @default(cuid())
  titulo           String
  descricao        String?
  // tipo: ONBOARDING | SEMANAL | MENSAL | ESPECIAL
  tipo             String
  // categoria: PERFIL | JOB | PARCERIA | SOCIAL | FINANCEIRO
  categoria        String
  recompensaTokens Int
  icone            String  @default("🎯")
  condicao         String?
  ativo            Boolean @default(true)
  // repeticao: UNICA | SEMANAL | MENSAL
  repeticao        String  @default("UNICA")

  completadas AdvogadoTarefa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, ativo])
  @@index([categoria])
  @@map("tarefas_token")
}

model AdvogadoTarefa {
  id           String   @id @default(cuid())
  completadaEm DateTime @default(now())
  tokensGanhos Int

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  tarefaId String
  tarefa   TarefaToken @relation(fields: [tarefaId], references: [id])

  createdAt DateTime @default(now())

  @@unique([advogadoId, tarefaId])
  @@index([advogadoId, completadaEm])
  @@map("advogado_tarefas")
}

model IndicacaoToken {
  id              String  @id @default(cuid())
  // status: PENDENTE | APROVADA | CANCELADA
  status          String  @default("PENDENTE")
  tokensCreditos  Int?
  codigoIndicacao String  @unique

  indicadorId String
  indicador   Advogado @relation("IndicacaoIndicador", fields: [indicadorId], references: [id])

  indicadoId String?
  indicado   Advogado? @relation("IndicacaoIndicado", fields: [indicadoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([indicadorId])
  @@map("indicacoes_token")
}

model SaqueToken {
  id               String  @id @default(cuid())
  quantidadeTokens Int
  valorReais       Decimal
  // status: SOLICITADO | PROCESSANDO | PAGO | CANCELADO
  status           String  @default("SOLICITADO")
  pixChave         String
  asaasTransferId  String?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, status])
  @@map("saques_token")
}

model TokenParceiro {
  id        String  @id @default(cuid())
  nome      String
  descricao String?
  logoUrl   String?
  ativo     Boolean @default(true)
  slug      String  @unique
  chaveApi  String  @unique

  regras    RegraTokenParceiro[]
  historico HistoricoTokenParceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("token_parceiros")
}

model RegraTokenParceiro {
  id                    String    @id @default(cuid())
  // tipo: VISITA_SITE | USO_SERVICO | PUBLICIDADE | COMPRA | CADASTRO | CUSTOM
  tipo                  String
  titulo                String
  descricao             String?
  tokensRecompensa      Int
  limiteUsosPorAdvogado Int?
  limiteUsosTotal       Int?
  totalUsado            Int       @default(0)
  ativo                 Boolean   @default(true)
  validoAte             DateTime?
  condicaoJson          String?

  parceiroId String
  parceiro   TokenParceiro @relation(fields: [parceiroId], references: [id], onDelete: Cascade)

  historico HistoricoTokenParceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parceiroId, ativo])
  @@map("regras_token_parceiro")
}

model HistoricoTokenParceiro {
  id              String  @id @default(cuid())
  tokensCreditos  Int
  comprovanteJson String?

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  regraId String
  regra   RegraTokenParceiro @relation(fields: [regraId], references: [id])

  parceiroId String
  parceiro   TokenParceiro @relation(fields: [parceiroId], references: [id])

  createdAt DateTime @default(now())

  @@index([advogadoId, createdAt])
  @@index([parceiroId])
  @@map("historico_token_parceiro")
}

model PacoteConsulta {
  id           String  @id @default(cuid())
  nome         String
  descricao    String?
  consultasMes Int
  precoTokens  Int
  // planoMinimo: STARTER | PRO | ESCRITORIO
  planoMinimo  String
  ativo        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pacotes_consulta")
}

model SecretariaConversa {
  id          String  @id @default(cuid())
  // modulo: AGENDA | FINANCEIRO | CONTROLADORIA
  modulo      String
  clienteNome String?
  ativo       Boolean @default(true)

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  mensagens SecretariaMensagem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, modulo])
  @@map("secretaria_conversas")
}

model SecretariaMensagem {
  id           String @id @default(cuid())
  // papel: USER | ASSISTANT
  papel        String
  conteudo     String
  tokensUsados Int?

  conversaId String
  conversa   SecretariaConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversaId, createdAt])
  @@map("secretaria_mensagens")
}

model ConversaAgente {
  id                   String  @id @default(cuid())
  // canal: TESTE | WHATSAPP | WEB
  canal                String  @default("TESTE")
  clienteNome          String?
  clienteIdentificador String?
  ativo                Boolean @default(true)

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  mensagens MensagemAgente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advogadoId, ativo])
  @@index([canal])
  @@map("conversas_agente")
}

model MensagemAgente {
  id           String @id @default(cuid())
  // papel: USER | ASSISTANT
  papel        String
  conteudo     String
  tokensUsados Int?

  conversaId String
  conversa   ConversaAgente @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversaId, createdAt])
  @@map("mensagens_agente")
}

// ============================================================
// MARKETPLACE
// ============================================================

model AreaJuridica {
  id        String  @id @default(cuid())
  nome      String  @unique
  slug      String  @unique
  descricao String?
  icone     String?
  ativo     Boolean @default(true)
  ordem     Int     @default(0)

  jobs JobCatalogo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo, ordem])
  @@map("areas_juridicas")
}

model JobCatalogo {
  id        String  @id @default(cuid())
  titulo    String
  descricao String?
  // tipo: JUDICIAL | ADMINISTRATIVO | AMBOS
  tipo      String
  ativo     Boolean @default(true)
  aprovado  Boolean @default(true)

  areaId String
  area   AreaJuridica @relation(fields: [areaId], references: [id])

  sugeridoPorId String?
  sugeridoPor   Advogado? @relation("JobSugerido", fields: [sugeridoPorId], references: [id])

  ofertas JobOferta[]
  leads   Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([areaId, ativo, aprovado])
  @@index([tipo])
  @@map("jobs_catalogo")
}

model JobOferta {
  id               String   @id @default(cuid())
  descricaoCustom  String?
  valorEstimadoMin Decimal?
  valorEstimadoMax Decimal?
  comissaoPct      Float?
  destaque         Boolean  @default(false)
  totalLeads       Int      @default(0)
  totalFechados    Int      @default(0)
  ativo            Boolean  @default(true)

  advogadoId String
  advogado   Advogado @relation(fields: [advogadoId], references: [id], onDelete: Cascade)

  jobId String
  job   JobCatalogo @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([advogadoId, jobId])
  @@index([jobId, ativo])
  @@index([advogadoId, ativo])
  @@map("jobs_ofertas")
}

model Lead {
  id               String   @id @default(cuid())
  descricao        String
  estadoCliente    String
  valorEstimado    Decimal?
  // status: ABERTO | EM_NEGOCIACAO | FECHADO | CANCELADO
  status           String   @default("ABERTO")
  comissaoAcordada Float?

  jobId String
  job   JobCatalogo @relation(fields: [jobId], references: [id])

  advogadoCaptorId String
  advogadoCaptor   Advogado @relation("LeadCaptor", fields: [advogadoCaptorId], references: [id])

  advogadoMatchId String?
  advogadoMatch   Advogado? @relation("LeadMatch", fields: [advogadoMatchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId, status])
  @@index([advogadoCaptorId])
  @@index([advogadoMatchId])
  @@index([status])
  @@map("leads")
}
